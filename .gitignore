# ============================================================
# Confidential / PII — never publish student records
# ============================================================

# Per-student folders (advising MDs, checklist workbooks, contact info)
students/active/*
!students/active/.gitkeep
students/graduated/*
!students/graduated/.gitkeep
students/inactive/*
!students/inactive/.gitkeep

# Registrar grade scrapes (names, student numbers, grades)
raw/*
!raw/.gitkeep

# Official advisee rosters per semester (student names)
reference/rosters/*
!reference/rosters/.gitkeep

# Archived records — obsolete but kept (old calendars, rosters, grade monitoring)
archive/*
!archive/.gitkeep

# Derived data that contains student PII
tools/roster.json
ROSTER.md

# ============================================================
# System artifacts (disposable / machine-local)
# ============================================================

# SAAIS index cache — rebuilt from files at startup
*.sqlite3
*.db
saais.db

# Timestamped file backups (used when git backups are disabled)
.backups/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Claude Code local settings
.claude/settings.local.json

# Editors / OS
.vscode/
.idea/
Thumbs.db
.DS_Store
~$*.xlsx
